# GapGPT API configuration for SQLiRLLM
# Copy this file to ".env" and fill in your key. The ".env" file is git-ignored.
GAPGPT_API_KEY=YOUR_GAPGPT_API_KEY
GAPGPT_BASE_URL=https://api.gapgpt.app/v1

# Model assignment per tier (override if desired)
SQLIRLLM_PAYLOAD_MODEL=gapgpt-qwen-3.6
SQLIRLLM_ANALYSIS_MODEL=qwen3-coder
