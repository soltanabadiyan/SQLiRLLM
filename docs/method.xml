  <Methodology sourcePage="3">
    <DesignGoal>Balance semantic analysis and resource constraints while enforcing ethical safeguards.</DesignGoal>

    <Workflow>
      <Step order="1" name="Target Definition and Scoping">Operator defines the authorized testing boundary.</Step>
      <Step order="2" name="Hyperparameter Calibration">Sets RL exploration/exploitation balance and LLM temperature.</Step>
      <Step order="3" name="Strategic Planning Layer">Q-Learning chooses high-level attack vectors.</Step>
    </Workflow>

    <Architecture figureRef="Figure 1" sourcePage="3">
      <Layer name="Strategic Planning"/>
      <Layer name="Payload Generation" feature="ethical enforcement"/>
      <Layer name="Analysis Feedback Loop"/>
    </Architecture>

    <ComparisonTable id="Table I" sourcePage="3">
      <Row framework="SQLMap" rl="None" languageModel="None" ethics="Partial" payloads="Comprehensive" nature="Static"/>
      <Row framework="SSQLi" rl="SAC" languageModel="None" ethics="None" evasion="97.39%" semantics="None"/>
      <Row framework="XPLOITSQL" rl="Actor-Critic" languageModel="T5" ethics="None" approach="LLM+RL" cost="High"/>
      <Row framework="SQLiRLLM" rl="Q-Learning" languageModel="Multi-model" ethics="Yes" nature="Multi-tier, Ethical"/>
    </ComparisonTable>

    <Tier id="1" name="Strategic Planning Layer" sourcePage="3-4">
      <Algorithm>Tabular Q-Learning</Algorithm>
      <Rationale>Interpretability, low computational overhead, convergence in structured SQL settings.</Rationale>
      <StateSpace sourcePage="4">
        <Dimension name="Framework Type" values="Laravel, Django, etc."/>
        <Dimension name="Database System" values="MySQL, Oracle"/>
        <Dimension name="WAF Presence" values="present, absent"/>
        <Dimension name="Testing Phase" values="Initial, Refinement, Exploitation, Verification"/>
      </StateSpace>
      <ActionSpace sourcePage="4">
        <Action>UNION-based</Action>
        <Action>Error-based</Action>
        <Action>Boolean-based blind</Action>
        <Action>Time-based blind</Action>
        <Action>Stacked queries</Action>
        <Action>Second-order injection</Action>
      </ActionSpace>
    </Tier>

    <Tier id="2" name="Payload Generation Layer" sourcePage="4">
      <Model name="Phi-3 Mini" parameters="3.8B"/>
      <FineTuning method="LoRA">
        <TunedParameters percentage="~0.5%" count="~19M"/>
        <TrainingTime>~8 hours on a single GPU</TrainingTime>
      </FineTuning>
      <TrainingDataset>
        <Size>60,000 labeled SQLi examples</Size>
        <Source>SSQLi</Source>
        <Source>XPLOITSQL</Source>
        <Augmentation>Custom payloads for modern frameworks</Augmentation>
      </TrainingDataset>
      <PromptEngineering>Incorporates target syntax and WAF presence.</PromptEngineering>
    </Tier>

    <Tier id="3" name="Analysis and Reward Layer" sourcePage="4">
      <Model name="Qwen2.5-Coder-14B" usage="selective batch analysis"/>
      <RewardFunction>
        <Equation>R(s, a, s') = α·VDR(a) + β·ESR(a) − γ·FPR(a) − δ·Time(a)</Equation>
        <Parameter symbol="α" value="0.6" meaning="weight for Vulnerability Detection Rate"/>
        <Parameter symbol="β" value="0.3" meaning="weight for Ethical Safeguard Rating"/>
        <Parameter symbol="γ" value="0.1" meaning="weight for False Positive Rate"/>
        <Parameter symbol="δ" value="0.05" meaning="weight for Time cost"/>
        <Metric abbr="VDR" name="Vulnerability Detection Rate"/>
        <Metric abbr="ESR" name="Ethical Safeguard Rating"/>
        <Metric abbr="FPR" name="False Positive Rate"/>
        <EthicalViolationPenalty value="-100"/>
      </RewardFunction>
      <FeedbackLoop>Updates the Q-table until convergence.</FeedbackLoop>
    </Tier>
  </Methodology>

